<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sidebar Categorías</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <style>
    body {
      background: #f5f5f5;
      padding: 1.5rem;
      font-family: sans-serif;
    }

    /* Botón toggle */
    #menu-toggle {
      background: #111;
      color: #fff;
      border: none;
      padding: 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.05em;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: background 0.15s;
      margin-bottom: 12px;
    }
    #menu-toggle:hover {
      background: #333;
    }

    /* Sidebar */
    #sidebar-wrapper {
      width: 240px;
      min-height: 340px;
      background: #111;
      border-radius: 0 12px 12px 0;
      overflow: hidden;
      transition: width 0.25s ease;
      flex-shrink: 0;
    }
    #sidebar-wrapper.collapsed {
      width: 0;
    }

    .sidebar-title {
      font-size: 11px;
      letter-spacing: 0.1em;
      color: #888;
      padding: 16px 16px 6px;
      text-transform: uppercase;
    }

    /* Links de categoría */
    .nav-link-cat {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 16px;
      color: #ccc;
      font-size: 14px;
      text-decoration: none;
      border-radius: 6px;
      margin: 2px 8px;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
    }
    .nav-link-cat:hover,
    .nav-link-cat.active {
      background: #2a2a2a;
      color: #fff;
    }
    .nav-link-cat.active {
      border-left: 2px solid #C9A96E;
      padding-left: 14px;
    }

    .cat-icon {
      font-size: 15px;
      width: 20px;
      text-align: center;
    }

    .badge-cat {
      margin-left: auto;
      background: #2a2a2a;
      color: #888;
      font-size: 10px;
      padding: 2px 7px;
      border-radius: 999px;
    }
    .nav-link-cat.active .badge-cat {
      background: rgba(201,169,110,0.15);
      color: #C9A96E;
    }

    .divider {
      border: none;
      border-top: 0.5px solid #222;
      margin: 8px 16px;
    }

    /* Área de contenido */
    #content-area {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #999;
      font-size: 14px;
      border: 1px dashed #ddd;
      border-radius: 8px;
      min-height: 300px;
    }
  </style>
</head>
<body>

  <!-- Botón toggle -->
  <button id="menu-toggle" onclick="toggleSidebar()">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
         stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6"  x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
    Categorías
  </button>

  <!-- Wrapper principal -->
  <div id="wrapper" style="display: flex; gap: 16px;">

    <!-- Sidebar -->
    <div id="sidebar-wrapper">
      <div class="sidebar-title">Explorar</div>
      <nav>
        <a href="#" class="nav-link-cat active" onclick="setActive(this)">
          <span class="cat-icon">💎</span> Caravanas
          <span class="badge-cat">12</span>
        </a>
        <a href="#" class="nav-link-cat" onclick="setActive(this)">
          <span class="cat-icon">🔑</span> Llaveros
          <span class="badge-cat">8</span>
        </a>
        <a href="#" class="nav-link-cat" onclick="setActive(this)">
          <span class="cat-icon">📿</span> Collares
          <span class="badge-cat">15</span>
        </a>
        <a href="#" class="nav-link-cat" onclick="setActive(this)">
          <span class="cat-icon">🖼️</span> Prints
          <span class="badge-cat">6</span>
        </a>
        <hr class="divider">
        <a href="#" class="nav-link-cat" onclick="setActive(this)">
          <span class="cat-icon">⭐</span> Destacados
          <span class="badge-cat">4</span>
        </a>
        <a href="#" class="nav-link-cat" onclick="setActive(this)">
          <span class="cat-icon">🏷️</span> Ofertas
          <span class="badge-cat">3</span>
        </a>
      </nav>
    </div>

    <!-- Contenido -->
    <div id="content-area">
      Contenido de productos aquí
    </div>

  </div>

  <script>
    function toggleSidebar() {
      document.getElementById('sidebar-wrapper').classList.toggle('collapsed');
    }

    function setActive(el) {
      event.preventDefault();
      document.querySelectorAll('.nav-link-cat').forEach(a => a.classList.remove('active'));
      el.classList.add('active');
    }
  </script>

</body>
</html>